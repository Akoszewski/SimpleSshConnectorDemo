<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="28dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/title_configuration"
        android:textColor="@color/text_primary"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="6dp"
        android:text="@string/label_server_address"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/ipAddressEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:backgroundTint="@color/primary"
        android:hint="@string/hint_ssh_target"
        android:imeOptions="actionNext"
        android:inputType="textUri"
        android:singleLine="true"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:text="@string/label_remote_apk_path"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/remoteApkPathEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:backgroundTint="@color/primary"
        android:hint="@string/hint_remote_apk_path"
        android:imeOptions="actionNext"
        android:inputType="textUri"
        android:singleLine="true"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="6dp"
        android:text="@string/label_terminal_start_path"
        android:textColor="@color/text_primary"
        android:textSize="16sp"
        android:textStyle="bold" />

    <EditText
        android:id="@+id/terminalStartPathEditText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:backgroundTint="@color/primary"
        android:hint="@string/hint_terminal_start_path"
        android:imeOptions="actionNext"
        android:inputType="textUri"
        android:singleLine="true"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_muted" />

    <CheckBox
        android:id="@+id/installDownloadedApksCheckBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:buttonTint="@color/primary"
        android:text="@string/label_install_downloaded_apks"
        android:textColor="@color/text_primary"
        android:textSize="15sp" />

    <CheckBox
        android:id="@+id/uploadScreenshotsCheckBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="18dp"
        android:buttonTint="@color/primary"
        android:text="@string/label_upload_screenshots"
        android:textColor="@color/text_primary"
        android:textSize="15sp" />

    <Button
        android:id="@+id/generateButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/button_primary"
        android:text="@string/action_generate_key"
        android:textColor="@color/white" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/public_key_container_background"
        android:gravity="center_vertical"
        android:minHeight="104dp"
        android:orientation="horizontal"
        android:padding="12dp">

        <TextView
            android:id="@+id/publicKeyEditText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="monospace"
            android:gravity="top|start"
            android:hint="@string/hint_ssh_public_key"
            android:lineSpacingExtra="2dp"
            android:maxLines="5"
            android:minHeight="80dp"
            android:overScrollMode="ifContentScrolls"
            android:scrollbars="vertical"
            android:textIsSelectable="true"
            android:textColor="@color/public_key_text"
            android:textColorHint="@color/public_key_hint"
            android:textSize="13sp" />

        <ImageButton
            android:id="@+id/copyButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="12dp"
            android:background="@drawable/button_primary"
            android:contentDescription="@string/action_copy"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:padding="12dp"
            android:scaleType="center"
            android:src="@drawable/ic_content_copy_24"
            android:tint="@color/white" />
    </LinearLayout>
    </LinearLayout>
</ScrollView>
